APP_NAME="SIMRS Staging"
APP_ENV=staging
# Leave APP_KEY unset on first run - the entrypoint generates and persists
# one to .env inside the container. Once generated, fetch it with
# `docker compose exec app php artisan key:generate --show` and set it here.
APP_DEBUG=false
APP_URL=http://staging.simrs.example.local

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Octane / FrankenPHP ---
OCTANE_SERVER=frankenphp
OCTANE_HTTPS=false

# --- External SQL Server (legacy DB, already migrated) ---
# DB_HOST must be reachable from inside the `app` container - "localhost"
# refers to the container itself, NOT the Docker host. If SQL Server runs on
# the same machine as Docker, use "host.docker.internal" (resolved via the
# extra_hosts entry in docker-compose.yml). Otherwise use the real hostname/IP.
DB_CONNECTION=sqlsrv
DB_HOST=your-sqlserver-host
DB_PORT=1433
DB_DATABASE=simrs
DB_USERNAME=simrs_app
DB_PASSWORD=changeme
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERTIFICATE=true

CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
BROADCAST_DRIVER=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@simrs.example.local"
MAIL_FROM_NAME="${APP_NAME}"
